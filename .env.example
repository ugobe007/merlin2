# Environment Variables

# Supabase Configuration (for when we migrate from localStorage)
VITE_SUPABASE_URL=your-project-url-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Auth Configuration
VITE_AUTH_PROVIDER=localStorage  # Options: localStorage, supabase

# App Configuration
VITE_APP_NAME=Merlin BESS
VITE_APP_VERSION=2.0.0

# ═══════════════════════════════════════════════════════════════════════════════
# SSOT ALERT NOTIFICATIONS
# Configure these to receive email/SMS when SSOT validation fails
# ═══════════════════════════════════════════════════════════════════════════════

# Email alerts via Resend (https://resend.com - free tier: 3000 emails/month)
VITE_RESEND_API_KEY=re_xxxxxxxxxxxx
VITE_ALERT_EMAIL=your-email@example.com

# SMS alerts via Twilio (https://twilio.com)
VITE_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
VITE_TWILIO_AUTH_TOKEN=your-auth-token
VITE_TWILIO_FROM_NUMBER=+1234567890
VITE_ALERT_PHONE=+1234567890

# Slack alerts (create incoming webhook in Slack)
VITE_SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/xxx/xxx

# ═══════════════════════════════════════════════════════════════════════════════
# STRIPE CONFIGURATION
# Get keys from: https://dashboard.stripe.com/apikeys
# ═══════════════════════════════════════════════════════════════════════════════
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx

# Third-party API Keys
VITE_NREL_API_KEY=your-nrel-api-key        # https://developer.nrel.gov/signup/
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key  # Google Cloud Console → Maps JS + Places APIs
VITE_VISUAL_CROSSING_API_KEY=your-visual-crossing-key  # https://www.visualcrossing.com/
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════════════════════════
# AI & INTELLIGENCE SERVICES (Phase 2+)
# For intelligent opportunity scraping with entity extraction and enrichment
# ═══════════════════════════════════════════════════════════════════════════════

# OpenAI API - Entity extraction and analysis (~$0.01/opportunity)
# Get key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-proj-your_key_here

# Hunter.io - Email discovery for decision makers (500 requests/month free)
# Get key from: https://hunter.io/api
VITE_HUNTER_API_KEY=your_hunter_key_here

# Clearbit - Company metadata enrichment (50 requests/month free)
# Get key from: https://clearbit.com/docs
VITE_CLEARBIT_API_KEY=your_clearbit_key_here

# BuildZoom - Construction permit tracking (contact for API access)
VITE_BUILDZOOM_API_KEY=your_buildzoom_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS - Enable/Disable AI & Enrichment Features
# ═══════════════════════════════════════════════════════════════════════════════

# Enable AI-powered entity extraction (requires OpenAI API key)
VITE_ENABLE_AI_ANALYSIS=false

# Enable email enrichment for decision makers (requires Hunter.io key)
VITE_ENABLE_EMAIL_ENRICHMENT=false

# Enable company metadata enrichment (requires Clearbit key)
VITE_ENABLE_COMPANY_ENRICHMENT=false

# Enable webhook notifications for new high-value opportunities
VITE_ENABLE_WEBHOOKS=false

# ═══════════════════════════════════════════════════════════════════════════════
# WEBHOOK CONFIGURATION - Notifications for New Opportunities
# ═══════════════════════════════════════════════════════════════════════════════

# Slack webhook for opportunity notifications
VITE_SLACK_OPPORTUNITY_WEBHOOK=https://hooks.slack.com/services/xxx/xxx/xxx

# Email notifications via Resend
VITE_OPPORTUNITY_ALERT_EMAIL=sales@yourcompany.com

# ═══════════════════════════════════════════════════════════════════════════════
# SCRAPER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Minimum confidence score to save opportunities (0-100)
VITE_MIN_CONFIDENCE_SCORE=50

# Maximum age of articles to process (in days)
VITE_MAX_ARTICLE_AGE_DAYS=30

# Scraper run interval (in milliseconds, default 1 hour)
VITE_SCRAPER_INTERVAL_MS=3600000
