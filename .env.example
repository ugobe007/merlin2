# Server-side EPC vision API
# Used by api/analyze-site.js. Do not expose this as VITE_*.
# For local dev, copy this file to .env.local in /Users/robertchristopher/merlin-v2.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini

# Local full-stack dev API URL
# npm run dev:full sets this automatically. Set manually only if running custom ports.
VITE_EPC_ANALYZE_API_URL=/api/analyze-site

# Existing live-data APIs used by src/DataService.js
VITE_NREL_API_KEY=DEMO_KEY
VITE_OPENEI_API_KEY=
VITE_EIA_API_KEY=
