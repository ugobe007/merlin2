{
  "@context": {
    "@vocab": "https://merlin.energy/ontology/business#",
    "schema": "https://schema.org/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "merlin": "https://merlin.energy/ontology/"
  },
  "@graph": [
    {
      "@id": "merlin:BusinessDomainOntology",
      "@type": "owl:Ontology",
      "rdfs:label": "Merlin Business Domain Ontology",
      "rdfs:comment": "Formal ontology of Merlin's business model, market segments, revenue streams, and competitive positioning",
      "owl:versionInfo": "1.0.0"
    },

    {
      "@id": "merlin:MerlinPlatform",
      "@type": "owl:Class",
      "rdfs:label": "Merlin Platform",
      "rdfs:comment": "The overarching Merlin software platform powering all products",
      "merlin:products": ["MerlinPro", "SMBVerticals", "PartnerAPI"],
      "merlin:coreEngine": "TrueQuote™",
      "merlin:positioning": "The only platform combining enterprise BESS quoting with SMB lead generation at scale",
      "merlin:tagline": "From quote to close in 5 minutes"
    },

    {
      "@id": "merlin:CustomerSegment",
      "@type": "owl:Class",
      "rdfs:label": "Customer Segment",
      "rdfs:comment": "A distinct group of customers with shared needs and buying behaviors",
      "merlin:instances": [
        {
          "@id": "merlin:EPC",
          "rdfs:label": "Engineering, Procurement & Construction Firm",
          "merlin:abbreviation": "EPC",
          "merlin:primaryPain": "BESS quote creation takes 90+ hours",
          "merlin:merlinSolution": "5-minute TrueQuote™ generation",
          "merlin:budgetAuthority": "high",
          "merlin:dealSize": "$500K-$50M projects",
          "merlin:buyerProduct": "MerlinPro",
          "merlin:acquisitionChannel": ["trade-shows", "linkedin", "partner-network"]
        },
        {
          "@id": "merlin:BatteryIntegrator",
          "rdfs:label": "Battery Storage Integrator",
          "merlin:primaryPain": "Needs fast accurate quotes to win competitive bids",
          "merlin:merlinSolution": "Instant benchmark-backed proposals",
          "merlin:budgetAuthority": "high",
          "merlin:buyerProduct": "MerlinPro",
          "merlin:competitiveAdvantage": "18x faster than manual process"
        },
        {
          "@id": "merlin:SMBOperator",
          "rdfs:label": "Small-to-Medium Business Operator",
          "merlin:primaryPain": "Doesn't know if BESS is right for their facility",
          "merlin:merlinSolution": "Industry-specific instant ROI analysis",
          "merlin:budgetAuthority": "medium",
          "merlin:dealSize": "$100K-$5M projects",
          "merlin:buyerProduct": "SMBVerticals",
          "merlin:acquisitionChannel": ["google-search", "industry-associations", "linkedin"]
        },
        {
          "@id": "merlin:BatteryManufacturer",
          "rdfs:label": "Battery Manufacturer",
          "merlin:primaryPain": "Needs qualified leads and sales tools for distribution channels",
          "merlin:merlinSolution": "White-label TrueQuote™ API + lead flow",
          "merlin:budgetAuthority": "very-high",
          "merlin:buyerProduct": "PartnerAPI",
          "merlin:dealSize": "$50K-$500K annual contracts"
        }
      ]
    },

    {
      "@id": "merlin:RevenueStream",
      "@type": "owl:Class",
      "rdfs:label": "Revenue Stream",
      "rdfs:comment": "A distinct mechanism by which Merlin generates revenue",
      "merlin:instances": [
        {
          "@id": "merlin:SaaSSubscription",
          "rdfs:label": "SaaS Subscription (Merlin Pro)",
          "merlin:model": "monthly-subscription",
          "merlin:grossMargin": 0.85,
          "merlin:tiers": [
            { "name": "Starter", "price": 299, "period": "month" },
            { "name": "Professional", "price": 599, "period": "month" },
            { "name": "Enterprise", "price": 999, "period": "month" }
          ],
          "merlin:arPotential": "$600K ARR at 100 customers",
          "merlin:churnBenchmark": "< 5% monthly"
        },
        {
          "@id": "merlin:LeadGeneration",
          "rdfs:label": "Lead Generation (SMB Verticals)",
          "merlin:model": "cost-per-lead",
          "merlin:grossMargin": 0.60,
          "merlin:leadPricing": {
            "car-wash": 150,
            "hotel": 200,
            "data-center": 500,
            "ev-charging": 300,
            "restaurant": 100,
            "office": 150,
            "warehouse": 200,
            "manufacturing": 400,
            "university": 300,
            "hospital": 400
          },
          "merlin:revenueTarget": "$2.5M at 10,000 leads/year"
        },
        {
          "@id": "merlin:PartnerAPILicensing",
          "rdfs:label": "Partner API Licensing",
          "merlin:model": "annual-license",
          "merlin:status": "planned",
          "merlin:targetCustomers": ["battery-manufacturers", "solar-companies", "epcs"],
          "merlin:pricingRange": [50000, 500000],
          "merlin:grossMargin": 0.90
        }
      ]
    },

    {
      "@id": "merlin:CompetitorLandscape",
      "@type": "owl:Class",
      "rdfs:label": "Competitive Landscape",
      "rdfs:comment": "Competing products and services in the BESS quoting and energy intelligence market",
      "merlin:competitors": [
        {
          "@id": "merlin:HomerEnergy",
          "rdfs:label": "Homer Energy (NREL spinoff)",
          "merlin:type": "simulation-software",
          "merlin:pricing": "$3000-15000/year",
          "merlin:targetUser": "engineers",
          "merlin:weakness": "Complex to use, no SMB vertical, no lead gen",
          "merlin:merlinAdvantage": "18x faster, purpose-built for quoting not research"
        },
        {
          "@id": "merlin:EnerNOC",
          "rdfs:label": "EnerNOC / Enel X",
          "merlin:type": "energy-management",
          "merlin:weakness": "Enterprise-only, no SMB focus, high implementation cost",
          "merlin:merlinAdvantage": "SMB accessible, self-serve, instant ROI"
        },
        {
          "@id": "merlin:GenericCalculators",
          "rdfs:label": "Generic Energy Calculators (Excel/web)",
          "merlin:type": "calculation-tools",
          "merlin:weakness": "Manual, no real utility data, no degradation modeling, not accurate",
          "merlin:merlinAdvantage": "Automated, benchmark-backed, 47-variable model"
        }
      ],
      "merlin:keyDifferentiator": "Only platform combining enterprise BESS quoting (SaaS) with SMB lead generation — competitors do one or the other"
    },

    {
      "@id": "merlin:IndustrySMBVertical",
      "@type": "owl:Class",
      "rdfs:label": "SMB Industry Vertical",
      "rdfs:comment": "An industry-specific lead generation product powered by Merlin's core engine",
      "merlin:instances": [
        {
          "@id": "merlin:CarWashVertical",
          "rdfs:label": "Car Wash Energy",
          "merlin:slug": "car-wash",
          "merlin:domain": "carwashenergy.com",
          "merlin:loadProfile": "high peak demand from compressors and water heating",
          "merlin:primarySavings": "demand-charges",
          "merlin:avgProjectSize": "$500K",
          "merlin:leadValue": 150,
          "merlin:status": "active",
          "merlin:industrySize": "60,000+ car washes in USA"
        },
        {
          "@id": "merlin:HotelVertical",
          "rdfs:label": "Hotel Power",
          "merlin:slug": "hotel",
          "merlin:loadProfile": "24/7 base load with peaks for HVAC and events",
          "merlin:primarySavings": "demand-charges + TOU arbitrage",
          "merlin:avgProjectSize": "$800K",
          "merlin:leadValue": 200,
          "merlin:status": "active",
          "merlin:industrySize": "55,000+ hotels in USA"
        },
        {
          "@id": "merlin:DataCenterVertical",
          "rdfs:label": "Data Center Power",
          "merlin:slug": "data-center",
          "merlin:loadProfile": "very high, constant, predictable",
          "merlin:primarySavings": "backup power + demand charges",
          "merlin:avgProjectSize": "$5M",
          "merlin:leadValue": 500,
          "merlin:status": "active",
          "merlin:industrySize": "5,000+ data centers in USA"
        }
      ]
    },

    {
      "@id": "merlin:SalesProcess",
      "@type": "owl:Class",
      "rdfs:label": "Merlin Sales Process",
      "rdfs:comment": "The canonical sales journey from prospect to customer",
      "merlin:stages": [
        {
          "@id": "merlin:Discovery",
          "rdfs:label": "Discovery",
          "merlin:description": "Prospect finds Merlin via SMB vertical or direct search",
          "merlin:tools": ["SEO content", "Google Ads", "Industry partnerships"],
          "merlin:conversionTarget": "10% to wizard completion"
        },
        {
          "@id": "merlin:Qualification",
          "rdfs:label": "Qualification (Wizard Steps 1-3)",
          "merlin:description": "Prospect provides business type, location, and energy profile",
          "merlin:dataCollected": ["industry", "zipCode", "peakDemand", "monthlyBill"],
          "merlin:conversionTarget": "70% completion rate"
        },
        {
          "@id": "merlin:Analysis",
          "rdfs:label": "TrueQuote™ Analysis (Wizard Steps 4-5)",
          "merlin:description": "System automatically sizes BESS and calculates ROI",
          "merlin:timing": "< 5 seconds",
          "merlin:output": "System size, cost, savings, payback, NPV, IRR"
        },
        {
          "@id": "merlin:LeadCapture",
          "rdfs:label": "Lead Capture (Wizard Step 6)",
          "merlin:description": "Prospect provides contact info to see full quote",
          "merlin:dataCollected": ["name", "email", "company", "phone"],
          "merlin:conversionTarget": "40% of completers"
        },
        {
          "@id": "merlin:LeadRouting",
          "rdfs:label": "Lead Routing",
          "merlin:description": "Qualified lead sent to installer/partner network",
          "merlin:sla": "Lead contacted within 24 hours",
          "merlin:revenueEvent": "Lead sale ($50-500)"
        }
      ]
    },

    {
      "@id": "merlin:KPIDashboard",
      "@type": "owl:Class",
      "rdfs:label": "Key Performance Indicators",
      "rdfs:comment": "The canonical metrics Merlin tracks daily to measure business health",
      "merlin:metrics": [
        {
          "id": "wizard_starts",
          "label": "Wizard Starts (24h)",
          "type": "count",
          "target": "> 100/day"
        },
        {
          "id": "wizard_completions",
          "label": "Wizard Completions (24h)",
          "type": "count",
          "target": "> 70/day (70% completion)"
        },
        {
          "id": "leads_captured",
          "label": "Leads Captured (24h)",
          "type": "count",
          "target": "> 28/day (40% of completions)"
        },
        {
          "id": "mrr",
          "label": "Monthly Recurring Revenue",
          "type": "currency",
          "target": "$50,000/month"
        },
        {
          "id": "quote_accuracy",
          "label": "TrueQuote Accuracy Score",
          "type": "percent",
          "target": "> 95%"
        },
        {
          "id": "system_uptime",
          "label": "System Uptime",
          "type": "percent",
          "target": "99.9%"
        },
        {
          "id": "p95_latency",
          "label": "P95 Page Load Latency",
          "type": "milliseconds",
          "target": "< 3000ms"
        }
      ]
    }
  ]
}
